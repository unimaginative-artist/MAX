# MAX Environment Variables
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────────────────
# Tier routing:
#   fast  → Ollama gemma3:4b  (heartbeats, web search, yes/no, background)
#   smart → DeepSeek chat     (all user conversations, planning, reasoning)
#   code  → DeepSeek reasoner (code generation, /reason, self-edit)
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (fast tier) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_FAST=gemma3:4b

# ── DeepSeek (smart + code tier) ──────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_CODE_MODEL=deepseek-reasoner

# ── Server ────────────────────────────────────────────────────────────────────
MAX_PORT=3100

# ── SOMA bridge (optional) ────────────────────────────────────────────────────
SOMA_URL=http://localhost:3001

# ── Discord notifications ──────────────────────────────────────────────────────
# Optional: override the notification channel (otherwise uses the channel from discord.setup)
# DISCORD_CHANNEL_ID=