{
  "name": "max-agent",
  "version": "0.1.0",
  "description": "MAX — autonomous engineering agent. Drive, heartbeat, swarm, personas, 3-tier memory.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node launcher.mjs",
    "chat": "node launcher.mjs --mode chat",
    "swarm": "node launcher.mjs --mode swarm",
    "api": "node launcher.mjs --mode api",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/unit --passWithNoTests",
    "test:unit:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/unit --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js test/integration --passWithNoTests"
  },
  "build": {
    "appId": "com.barry.maxwell",
    "productName": "Maxwell",
    "asar": false,
    "directories": {
      "buildResources": "electron/assets",
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "core/**/*",
      "server/**/*",
      "tools/**/*",
      "memory/**/*",
      "personas/**/*",
      "swarm/**/*",
      "onboarding/**/*",
      "config/api-keys.env.example",
      "launcher.mjs",
      "package.json",
      "!**/.max/**",
      "!**/node_modules/playwright/**",
      "!**/node_modules/puppeteer-core/**",
      "!dist-electron/**",
      "!**/*.log"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Maxwell",
      "installerHeader": "electron/assets/installer-header.bmp",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.6.2",
    "blessed": "^0.1.81",
    "bonjour-service": "^1.3.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "chrome-launcher": "^1.2.1",
    "discord.js": "^14.25.1",
    "express": "^4.18.3",
    "imapflow": "^1.2.10",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "playwright": "^1.59.1",
    "puppeteer-core": "^24.38.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "engineering",
    "swarm"
  ],
  "license": "MIT",
  "author": "Barry",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^10.0.2",
    "jest": "^30.2.0"
  }
}
