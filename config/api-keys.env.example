# MAX API Keys — copy to api-keys.env and fill in at least one
# cp config/api-keys.env.example config/api-keys.env

# ── Local (no key needed) ─────────────────────────────────────────────────

# Ollama — https://ollama.com — install, run `ollama pull llama3.2`, done
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Cloud (optional, pick one) ────────────────────────────────────────────

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Any OpenAI-compatible endpoint (LM Studio, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:1234/v1

# ── Server ────────────────────────────────────────────────────────────────
MAX_PORT=3100

# ── Integrations (optional — or just tell MAX in chat and he'll set it up) ─

# Discord bot token — create a bot at https://discord.com/developers/applications
# Enable: Message Content Intent, Server Members Intent
# Invite URL: https://discord.com/api/oauth2/authorize?client_id=YOUR_ID&permissions=2048&scope=bot
# You can also just paste your token into the MAX chat and he'll handle the rest.
# DISCORD_BOT_TOKEN=your-bot-token-here

# Email — credentials saved to .max/integrations.json when you tell MAX in chat.
# For Gmail: use an App Password (Google Account → Security → App Passwords).
# DO NOT use your main Google password here.
# EMAIL_ADDRESS=you@gmail.com
# EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
