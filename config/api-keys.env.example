# MAX API Keys — copy to api-keys.env and fill in at least one
# cp config/api-keys.env.example config/api-keys.env

# ── Local (no key needed) ─────────────────────────────────────────────────

# Ollama — https://ollama.com — install, run `ollama pull llama3.2`, done
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Cloud (optional, pick one) ────────────────────────────────────────────

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Any OpenAI-compatible endpoint (LM Studio, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:1234/v1

# ── Server ────────────────────────────────────────────────────────────────
MAX_PORT=3100
